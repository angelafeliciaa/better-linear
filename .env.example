# Session encryption — 32+ random bytes (e.g. `openssl rand -hex 32`)
SESSION_PASSWORD=

# Linear OAuth (optional — if unset, only personal-API-key flow is shown)
# Register an OAuth app at https://linear.app/settings/api/applications
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_REDIRECT_URI=http://localhost:3000/api/auth/callback

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
